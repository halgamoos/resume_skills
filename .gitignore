# Dependencies
node_modules/

# Your personal resume outputs — output/ is tracked as an empty folder via .gitkeep.
# All generated files stay local and are never committed.
output/*
!output/.gitkeep

# Your generated build scripts — contain your personal resume content (name, contact,
# work history). Claude generates these from your corpus. See the .example.mjs files
# for the expected shape. Fork users: Claude will generate your own copies on first run.
build_resume.mjs
build_resume_pdf.mjs

# Your personal work history logs — corpus/ is tracked as an empty folder via .gitkeep.
# All files you write inside corpus/ are personal data and stay on your machine only.
# Fork this repo to use it for yourself.
corpus/*
!corpus/.gitkeep

# Claude Code personal settings (API keys, local preferences)
.claude/settings.local.json

# OS junk
.DS_Store
Thumbs.db
